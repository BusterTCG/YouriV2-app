# Youri V2 — template d'environnement
# Copie ce fichier en `.env.local` (dev) ou `.env` (prod) et remplis les valeurs.
# `.env*` est gitignored (sauf ce template) → tes secrets restent locaux.

# ═══════════════════════════════════════════════════════════════════════════
# BASE DE DONNÉES (Youri V2 — Postgres dédié sur le VPS, SQLite en dev local)
# ═══════════════════════════════════════════════════════════════════════════

# Dev local : SQLite fichier (rapide à mettre en place, pas de service à démarrer)
# Prod      : postgresql://user:pass@localhost:5432/youri (base dédiée sur le VPS)
DATABASE_URL="file:./dev.db"

# ═══════════════════════════════════════════════════════════════════════════
# AUTH MULTI-USER (Sprint 1)
# ═══════════════════════════════════════════════════════════════════════════

# Secret de signature des cookies de session (JWT HS256). 32+ caractères.
# Génère via : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANT : si tu changes ce secret, toutes les sessions existantes deviennent
# invalides (= tous les users doivent se re-connecter sur tous leurs appareils).
SESSION_SECRET=

# Emails Google autorisés à se connecter via OAuth — séparés par virgule.
# Tout autre email est refusé. 3 emails Pangee Prod attendus.
AUTH_ALLOWED_EMAILS=stan@pangeeprod.com,certe@pangeeprod.com,admin@pangeeprod.com

# Mot de passe de secours (fallback si Google est indisponible). Le même
# pour tous les users — chaque user choisit son email après login mdp.
# En prod, change-le pour un truc costaud (16+ chars random).
APP_PASSWORD=

# Redirect URI OAuth Google pour l'AUTH.
# À déclarer dans Google Cloud Console → OAuth Client → Authorized redirect URIs.
# Local dev : http://localhost:3000/api/auth/google/callback
# Prod      : https://app.pangeeprod.com/api/auth/google/callback
GOOGLE_SIGNIN_REDIRECT_URI=http://localhost:3000/api/auth/google/callback

# Google OAuth Client credentials (crée un OAuth Client distinct de KN dans
# le même Google Cloud Project — plus propre que mutualiser).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ═══════════════════════════════════════════════════════════════════════════
# INTER-APP API (Youri V2 → KuroNeko-App)
# ═══════════════════════════════════════════════════════════════════════════
#
# KN expose un annuaire Contact / Venue / VenueRoom via /api/external/*.
# Youri V2 consomme cette API depuis lib/kn-client.ts (Sprint 2) avec ce token.
#
# IMPORTANT : la valeur doit être IDENTIQUE à celle dans le .env de
# KuroNeko-App. Voir docs/architecture-decisions.md § Architecture multi-app.
INTER_APP_TOKEN=

# URL de base de l'API KN.
# Dev local (KN tourne aussi en local sur 3000) : http://localhost:3000
# Prod                                          : https://app.kuronekoprod.com
KN_API_BASE_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════════════════
# APP URL (utilisé par les routes OAuth pour les redirects)
# ═══════════════════════════════════════════════════════════════════════════

# Local dev : http://localhost:3000
# Prod      : https://app.pangeeprod.com
NEXT_PUBLIC_APP_URL=http://localhost:3000
