// Youri V2 — Prisma schema
// Source : docs/architecture-decisions.md § Modèle de données
// Local : SQLite. Production (VPS) : switch to postgresql via DATABASE_URL.
//
// Sprint 0 : datasource + generator + AppSetting (key/value store, sert de
// smoke test pour la 1re migration et de base future pour les settings runtime).
// Les modèles métier (User, Artist, Deal, Task, etc.) viennent au Sprint 1+.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── ENUMS ───────────────────────────

/// Rôle d'un utilisateur. Convention décisions verrouillées :
/// - ADMIN : Stan uniquement. Peut gérer les autres users + éditer les
///   templates de tâches (Sprint 6).
/// - MEMBER : tout le monde fait TOUT (créer/modifier/supprimer n'importe
///   quel deal/tâche/artiste). Pas de restrictions métier.
/// Cf. docs/architecture-decisions.md § Users & permissions.
enum UserRole {
  ADMIN
  MEMBER
}

/// Source de l'authentification (audit, debug).
enum AuthSource {
  GOOGLE
  PASSWORD
}

/// Catégorie d'un deal Pangee. 3 valeurs (vs 5 côté KN — cf. règles V2) :
/// - BOOKING : cession/booking d'artistes auprès d'organisateurs (mono-date)
/// - PROD_EXE : production exécutive 15 % (multi-date, Sprint 4)
/// - CACHETS : gestion paie intermittents (multi-date, Sprint 5)
/// Sprint 3 = BOOKING uniquement. L'enum complet est créé dès Phase 3.1
/// pour éviter une migration future. Les filtres `/deals/booking` etc.
/// sélectionnent strictement par catégorie.
enum DealCategory {
  BOOKING
  PROD_EXE
  CACHETS
}

/// Statut d'un deal — workflow manuel simple (cf. décision archi B1 verrouillée).
/// - LEAD : prospect / négociation amont
/// - EN_COURS : négociation avancée mais pas signée
/// - CONFIRME : deal signé / confirmé
/// - ANNULE : pas fait (négo échouée ou annulation post-confirmation)
enum DealStatus {
  LEAD
  EN_COURS
  CONFIRME
  ANNULE
}

/// Statut de paiement — utilisé pour les 2 niveaux par artiste sur DealArtiste :
/// - paymentStatus = statut du cachet artiste (ce que l'artiste reçoit)
/// - commissionStatus = statut de la commission Pangee (ce que Pangee perçoit)
/// Les 2 sont indépendants car cachet et com sont facturés / payés séparément.
///
/// DISPUTE = paiement en litige (impayé contesté). Identique KN. Stan veut
/// le même wording / mêmes propositions que KN dans les Selects.
enum PaymentStatus {
  TO_INVOICE
  VALIDATED
  INVOICED
  PAID
  DISPUTE
  N_A
}

// ─────────────────────────── FDR / Feuille de route (Sprint 3.7) ───────────────────────────
//
// Reprise fidèle du modèle KN `EventBriefing` (cf. AGENTS.md règle copie
// fidèle KN). Adaptations Youri V2 :
//   - Pas de tables Hotel/Restaurant/Venue locales : tout en free-text +
//     adresse BAN (Venue vit côté KN distant, snapshot pattern).
//   - Pas de relation Contact locale : BriefingContact stocke `contactId`
//     snapshot KN + champs inline (Pangee veut éviter de polluer l'annuaire
//     pour les rôles ponctuels VTC/runner).
//   - Multi-artiste : 1 FDR commune au deal (Stan validé 2026-05-26),
//     envoyée à tous les artistes du deal.
//   - Catégorie BOOKING uniquement pour Sprint 3.7 — PROD_EXE/CACHETS
//     viendront aux Sprints 4/5.

enum BriefingStatus {
  DRAFT
  COMPLETE
  SENT
}

enum TravelDirection {
  OUTBOUND
  RETURN
  INTER
}

enum BriefingRole {
  PRODUCTION
  REGISSEUR
  VTC
  TOUR_MANAGER
  ORGANISATEUR
  TECHNICIEN
  AUTRE
}

// ─────────────────────────── MANAGEMENT FEES (rémunération associés) ───────────────────────────
//
// Pangee verse à chaque associé (Stan/Certe/Angath) un % de la marge sur
// chaque deal, pour 2 catégories de prestation :
//   - APPORT : apport d'affaires (qui a ramené le deal)
//   - WORK   : travail effectif sur le deal (gestion de la date hors direction)
//
// Défaut 10% par catégorie, modifiable au cas par cas. Si N personnes sont
// sélectionnées dans une catégorie, le pool est réparti équitablement
// (pool ÷ N pour chaque associé).
//
// Stan 2026-05-26 : cadre juridique = convention de prestation entre Pangee
// et la société de chaque associé (Kuro Neko EURL Stan, SASU Certe, etc.).

enum ManagementFeeRole {
  APPORT // Apport d'affaires
  WORK // Travail effectif sur le deal
}

// ─────────────────────────── PROD EXÉCUTIVE (Sprint 4) ───────────────────────────
//
// Pangee Prod gère 3 modèles de contrat avec une salle pour les productions
// exécutives. Le modèle artiste est toujours implicite PROD_EXE (Pangee prend
// 15 % du CA billetterie, configurable par deal via `prodExePct`). Multi-date
// supporté via `multiDateDates` JSON (1 deal = 1 tournée / résidence).
//
// Copie fidèle du module Production de KuroNeko-App (cf. AGENTS.md), simplifiée
// pour n'exposer que PROD_EXE côté Pangee (pas de COPROD artiste).

/// Modèle de contrat avec la salle — détermine d'où vient le CA billetterie.
enum VenueDealKind {
  PROD // Pangee loue la salle, encaisse 100 % billetterie HT, paye location.
  CO_REAL // Salle gère, billetterie partagée. Pangee saisit sa part nette dans RECETTE_HT.
  CESSION // Prix fixe payé par la salle, pas de risque billetterie.
}

/// Type de ligne du tableau de production (recettes vs charges).
enum ProductionLineKind {
  REVENUE
  COST
}

/// Catégories prédéfinies des lignes de production. Reprise fidèle KN.
/// L'user peut préciser via `customLabel` (texte libre) pour les sous-entrées
/// (ex. VHR multi : train + hôtel + repas).
enum ProductionLineLabel {
  // ── Recettes
  RECETTE_HT // Billetterie nette Pangee (PROD/CO_REAL) ou prix de cession (CESSION).
  DL_PROD // Deal Live : montant additionnel par billet vendu, saisi à la main.
  // ── Charges
  CNM // Centre National de la Musique (taxe).
  SACD // Société des Auteurs et Compositeurs Dramatiques.
  LOCATION // Location de la salle (mode PROD principalement).
  VHR // Voyage / Hôtel / Repas (équipe + artistes).
  COM // Communication / promotion.
  TECH // Technique scénique (son, lumière, matériel).
  CAPTA // Captation audio/vidéo éventuelle.
  AUTRE // Catch-all texte libre (`customLabel` obligatoire).
}

// ─────────────────────────── USERS (Sprint 1) ───────────────────────────

/// Compte utilisateur Pangee Prod. 3 seedés au bootstrap :
/// Stan (ADMIN), Certe (MEMBER), Angath (MEMBER).
///
/// Pas de soft-delete (pas de `deletedAt`) — on désactive via `active: false`
/// au lieu de supprimer, pour préserver l'historique d'audit / completedBy
/// sur les tâches que l'user a validées (à venir Sprint 6).
model User {
  id String @id @default(cuid())

  /// Email principal (login). Pour les users avec Google OAuth, c'est aussi
  /// l'email Google. Unique.
  email String @unique

  /// Nom d'affichage (sidebar, badges, "Validé par X").
  name String

  /// Hash bcrypt du mot de passe de secours (fallback si Google down).
  /// Tous les users ont le même mdp au démarrage (APP_PASSWORD). Réinitia-
  /// lisable depuis /settings/users par l'ADMIN.
  passwordHash String

  /// Couleur d'identification de l'user (badges "assigné à", chips). Hex.
  color String @default("#3b82f6")

  /// Rôle (ADMIN | MEMBER). Voir enum UserRole pour les implications.
  role UserRole @default(MEMBER)

  /// Désactiver = empêche le login mais préserve l'historique des actions.
  /// Préféré à un soft-delete pour la traçabilité.
  active Boolean @default(true)

  /// Trace la dernière source d'auth (debug si problème OAuth vs mdp).
  lastAuthSource AuthSource?
  lastLoginAt    DateTime?

  /// Clé d'identification dans lib/pangee-team.ts (stan / certe / angath /
  /// null). Sert au pré-filtrage de la page /deals/management-fees sur
  /// l'associé connecté (Stan 2026-05-26). Migration future task #47 :
  /// remplacer lib/pangee-team.ts par un fetch dynamique des users avec
  /// pangeeKey défini.
  pangeeKey String?

  /// Relations d'audit — quel user a créé quel deal (multi-user audit léger).
  /// Sprint 10 ajoutera un AuditEntry plus complet pour les actions update/delete.
  dealsCreated Deal[] @relation("DealCreatedBy")

  /// Tâches que l'user a validées (audit Sprint 6 — Stan 2026-05-31).
  /// SetNull si user désactivé pour préserver la trace historique.
  tasksCompleted Task[] @relation("TaskDoneBy")

  /// Entrées d'audit dont l'user est l'acteur (Sprint 10). SetNull côté
  /// AuditEntry si l'user est supprimé, mais `actorName` garde la trace.
  auditEntries AuditEntry[] @relation("AuditActor")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────── MASTER DATA (Sprint 2) ───────────────────────────

/// Artiste managé / produit par Pangee Prod.
///
/// Table dédiée Youri — PAS partagée avec KuroNeko (roster différent).
/// Soft-deletable (`deletedAt`) avec garde côté server action : on bloque
/// la suppression si des DealArtiste actifs référencent l'artiste (cf.
/// docs/architecture-decisions.md § Cascade soft-delete). DealArtiste sera
/// ajouté Sprint 3.
///
/// Structure repompée à l'identique de KuroNeko-App (cf. AGENTS.md règle
/// "copie fidèle de KN") : avatar avec position de recadrage + fiche
/// ArtistProfile complète en relation 1-1 (identité civile, SACD,
/// intermittence, structure, RIB, bio, social).
model Artist {
  id String @id @default(cuid())

  /// Nom d'affichage de l'artiste. Unique pour éviter doublons accidentels.
  name String @unique

  /// Slug pour les URLs `/artistes/[slug]`. Généré depuis `name` via lib/slug.ts.
  /// Unique. Si l'user crée 2 fois "Jean Dupont", le slug aura un suffixe -2.
  slug String @unique

  /// Couleur d'identification (badges, chips, avatar). Hex.
  /// Pangee gère 50+ artistes — pas de couleurs distinctes par artiste
  /// (cf. règle 2026-05-26, lib/artists-constants.ts PANGEE_ARTIST_COLOR).
  /// On garde le champ en BDD pour compat / option future, mais l'UI
  /// force toujours la même couleur à la création/modif.
  color String @default("#2563eb")

  /// URL relative vers la photo d'avatar uploadée (ex. "/uploads/avatars/<id>-<ts>.jpg").
  /// Null = pas de photo, on affiche le fallback initiales+couleur. Fichier stocké
  /// dans `public/uploads/avatars/` côté serveur.
  avatarUrl String?

  /// Position horizontale du recadrage avatar dans le rond (0-100 %, défaut 50 = centré).
  /// Appliqué via CSS `object-position`. Permet de re-centrer la photo si le sujet
  /// n'est pas au milieu du fichier source (typique iPhone portrait).
  avatarPositionX Float @default(50)

  /// Position verticale du recadrage avatar (0-100 %, défaut 50 = centré).
  avatarPositionY Float @default(50)

  /// Notes libres internes (style musical, préférences, infos contractuelles
  /// rapides). La fiche complète vit dans ArtistProfile relation 1-1.
  notes String?

  /// Désactiver = masquer dans les listes par défaut. Soft-delete via
  /// `deletedAt` reste l'opération "définitive" (visible dans /trash Sprint 10).
  active Boolean @default(true)

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  profile      ArtistProfile?
  /// Deals où cet artiste apparaît (jointure DealArtiste avec cachet + com
  /// + statuts paiement individuels). Sprint 3+.
  dealArtistes DealArtiste[]
}

// ─────────────────────────── ARTIST PROFILE (Sprint 2-bis) ───────────────────────────
// Fiche complète d'identité, structure, RIB et communication d'un artiste.
// Relation 1-1 avec Artist (optionnelle — créée à la demande via upsert).
// Champs sensibles (Sécu, IBAN) gérés en masquage à l'affichage (composant InfoField).
//
// Schéma repris à l'identique de KuroNeko-App ArtistProfile (cf. AGENTS.md
// règle "copie fidèle de KN" — Pangee a le même besoin métier pour la
// gestion paie intermittents + facturation cachets).

model ArtistProfile {
  id       String @id @default(cuid())
  artistId String @unique
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  // 1 — Identité civile
  firstName            String?
  lastName             String?
  stageName            String?
  birthDate            DateTime?
  birthPlace           String?
  nationality          String?
  socialSecurityNumber String?
  intermittentNumber   String?
  sacdNumber           String?
  sncfCardNumber       String?
  dietaryRequirements  String?
  // NB : `nationality` retiré de l'UI (form + fiche) — colonne conservée pour
  // ne pas perdre l'historique. Plus lue ni écrite par l'app.

  // 2 — Coordonnées personnelles
  personalEmail String?
  personalPhone String?
  homeAddress   String?

  // 3 — Structure de facturation
  companyName      String?
  companyLegalForm String?
  companySiret     String?
  companySiren     String?
  companyVatNumber String?
  companyApeCode   String?
  companyAddress   String?
  spectacleLicense String?
  vatRegime        String?

  // 4 — Coordonnées bancaires
  bankIban   String?
  bankBic    String?
  bankName   String?
  bankHolder String?

  // 5 — Communication / Press kit
  bioShort        String?
  bioLong         String?
  pressPhotoUrl   String?
  websiteUrl      String?
  instagramHandle String?
  youtubeHandle   String?
  tiktokHandle    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────── DEALS (Sprint 3) ───────────────────────────
//
// Sprint 3 ne gère que `category=BOOKING` (mono-date). PROD_EXE (Sprint 4) et
// CACHETS (Sprint 5) sont multi-date — on ajoutera une table DealDate jointe
// à ce moment-là. L'enum DealCategory inclut déjà les 3 valeurs pour éviter
// une migration future.
//
// Pattern annuaire = snapshot (cf. project-youri-v2 décisions verrouillées) :
// Deal stocke organizerId/Name/Company/City + venueId/Name/City. Pas de
// relation Prisma — l'annuaire vit côté KN (lib/kn-client). On refetch via
// API KN uniquement quand l'user clique "Modifier ce contact" / "ce lieu".
//
// Multi-artiste : relation DealArtiste avec cachet + commission + 2 statuts
// paiement par artiste (cachet payé indépendant de com Pangee payée).
//
// Multi-user audit : createdById sur Deal (qui a créé). Sprint 10 ajoutera
// un AuditEntry plus complet pour update/delete.
//
// Soft-delete : deletedAt sur Deal et DealArtiste. Cascade côté server action
// (pas Prisma cascade qui supprimerait vraiment).

/// Deal Pangee — entité métier centrale du Sprint 3+. Représente une opération
/// commerciale (booking, prod exécutive, cachets) avec 1-N artistes.
model Deal {
  id String @id @default(cuid())

  /// Catégorie discriminante (BOOKING / PROD_EXE / CACHETS). Sprint 3 = BOOKING
  /// uniquement. Filtre strict côté pages `/deals/<categorie>`.
  category DealCategory

  /// Workflow simple manuel (LEAD → EN_COURS → CONFIRME / ANNULE).
  /// L'user passe les statuts à la main depuis la fiche deal.
  status DealStatus @default(LEAD)

  /// Titre court du deal (ex. "Nordine Ganso @ Comedy Club Paris").
  /// Souvent généré auto depuis artiste(s) + lieu, modifiable.
  title String

  /// Description / contexte libre (notes commerciales en amont, terms négociés).
  description String?

  /// Date principale du deal. Pour BOOKING (mono-date) c'est LA date du show.
  /// Pour PROD_EXE/CACHETS (multi-date) c'est la 1re date — la liste complète
  /// sera stockée dans DealDate (Sprint 4+).
  date DateTime

  /// Heure du show — texte libre ("20h30", "doors 19h / show 20h"). Pas
  /// parsé, juste affiché. Indépendant de la date pour préserver la flexibilité.
  showTime String?

  // ── Budget Pangee (modèle 2026-05-26 : budget global vs marge) ──
  // Stan a refondé le modèle : Pangee touche un budget global de l'organisateur,
  // paie les artistes (DealArtiste.cachetAmount) et les charges (DealCharge.amount),
  // et garde la différence = Marge Pangee. Plus de commission % par artiste.

  /// Budget Pangee = montant que l'organisateur paie à Pangee pour ce deal.
  /// Sert de base au calcul de la Marge Pangee = budget − total artistes − total charges.
  budgetAmount Decimal?

  /// Statut du budget côté Pangee (à facturer / facturée / encaissée / litige).
  /// En UI, sur la fiche deal, exposé comme checkbox simple "Encaissé"
  /// (true = PAID, false = N_A ou TO_INVOICE). Dans le tableau récap inline,
  /// Select 5 valeurs comme les autres statuts paiement.
  budgetPaymentStatus PaymentStatus @default(N_A)

  /// Mois où Pangee a encaissé le budget de l'organisateur (cash-flow réel).
  /// Sert au filtre période axis="paid" + reporting mensuel marge.
  budgetPaidAt DateTime?

  // ── Snapshot organisateur (Contact KN distant) ──
  /// ID du Contact KN au moment de la sélection. Refetch via kn-client.
  organizerId      String?
  /// Nom complet snapshotté (firstName + lastName concaténés ou company).
  /// Désync acceptable avec KN jusqu'au prochain "Modifier ce contact".
  organizerName    String?
  organizerCompany String?
  organizerCity    String?

  // ── Snapshot lieu (Venue KN distant) ──
  venueId      String?
  venueName    String?
  venueCity    String?
  /// Adresse libre (BAN data.gouv.fr) — utilisée quand le lieu n'est PAS un
  /// Venue référencé en BDD (ex. booking entreprise). Si venueId est null,
  /// venueCity est extraite automatiquement depuis cette adresse (regex code
  /// postal). Cas Stan 2026-05-26 : "booking en entreprise" sans référencer
  /// le lieu dans l'annuaire.
  venueAddress String?

  // ── Multi-artiste ──
  dealArtistes DealArtiste[]

  // ── Charges diverses (dépenses Pangee) ──
  dealCharges DealCharge[]

  // ── Management fees (Marge associés) ──
  /// Reversement Pangee → associés sous forme de prestation. 2 catégories :
  /// apport d'affaires + travail effectif. Voir model DealManagementFee.
  managementFees DealManagementFee[]

  // ── Feuille de route (Sprint 3.7) ──
  /// 1-1 optionnel : la FDR n'existe que si l'user l'a ouverte au moins
  /// une fois (auto-création via ensureBriefingWithPrefill). Cascade
  /// delete suit le soft-delete du Deal côté server action.
  briefing EventBriefing?

  // ── Spécifique Prod Exécutive (Sprint 4) ──
  /// Modèle de contrat avec la salle (PROD / CO_REAL / CESSION). Détermine
  /// l'interprétation de la ligne RECETTE_HT et le calcul du CA. Null pour
  /// les deals BOOKING / CACHETS (ne s'applique qu'à PROD_EXE).
  venueDealKind VenueDealKind?

  /// % du CA billetterie qui revient à Pangee (PROD_EXE). Défaut 15 — l'user
  /// peut override par deal si négociation spécifique. Sert au calcul auto
  /// de `commissionAmount` via `lib/finance/show-financials.ts`.
  prodExePct Decimal?

  /// % du budget que Pangee conserve sur un deal CACHETS — Sprint 5
  /// Stan 2026-05-28. Modèle Cachets : Pangee facture un tiers pour le compte
  /// d'un artiste, conserve `cachetsFeesPct`% (= Marge Brute, default 10%) et
  /// reverse le reste à l'artiste (= `DealArtiste.cachetAmount` auto-calc =
  /// budget × (100 − cachetsFeesPct) / 100).
  /// Override par deal si négociation spécifique.
  cachetsFeesPct Decimal?

  /// CACHETS uniquement (Stan 2026-05-28) — Si `true`, ce cachet est versé
  /// dans le cadre d'un spectacle que Pangee produit elle-même (un autre
  /// deal PROD_EXE) : pas de tiers qui facture en amont, pas de marge Pangee,
  /// pas de MF — juste une trace administrative pour la paie GUSO/CDDU.
  /// → `margeBrute = 0` ET `recomputeMfForDeal` met les MF à 0.
  linkedToOwnProd Boolean @default(false)

  /// % de co-réalisation avec la salle en mode CO_REAL — part Pangee sur la
  /// billetterie totale (le reste revient à la salle). Informatif.
  coRealKnPct Decimal?

  /// CA global billetterie HT en mode CO_REAL — avant partage avec la salle.
  /// Permet de calculer le ticket moyen sur le prix public.
  coRealGrossCa Decimal?

  /// Jauge totale de la salle (capacité max).
  capacity Int?
  /// Nombre de billets payants vendus.
  paying   Int?
  /// Nombre d'invités (gratuits).
  invited  Int?

  /// Mode multi-date activé pour les résidences / tournées.
  isMultiDate      Boolean @default(false)
  /// Nombre de représentations dans la série — calculé auto depuis
  /// `multiDateDates.length` quand renseigné.
  performanceCount Int?
  /// Liste des dates de la série (array de "YYYY-MM-DD"). Type Json côté
  /// Prisma → SQLite stocke en TEXT sérialisé, Postgres en JSON natif.
  multiDateDates   Json?

  /// Nom de scène/du spectacle (distinct du `title` qui est court).
  showName String?
  /// Heure de fin de la représentation (texte libre, identique à showTime).
  endTime  String?

  /// Suivi opérationnel : contrat signé.
  contractSigned Boolean @default(false)
  /// Suivi opérationnel : mise en vente billetterie effective.
  ticketingReady Boolean @default(false)
  /// URL externe vers la page billetterie.
  ticketingUrl   String?
  /// Suivi opérationnel : VHR (voyage/hôtel/repas) booké.
  vhrBooked      Boolean @default(false)

  /// VenueRoom snapshot (depuis annuaire KN) — la salle peut avoir plusieurs
  /// configurations (grande salle, petite salle, etc.).
  venueRoomId String?

  // ── Scalars financiers recalculés (Prod Exé) ──
  // Persistés à chaque mutation par `recomputeShowFinancials(dealId)`. La
  // fiche artiste lit ces scalars pour ses totaux "à facturer / encaissé".
  // Sur Booking ils restent null (le calcul Marge Pangee passe par
  // budgetAmount − Σartistes − Σcharges, pas par ces scalars).

  /// "Montant" générique (= revenue pour PROD_EXE, = budget pour BOOKING).
  /// Mappé en colonne tableau de la fiche artiste.
  grossAmount      Decimal?
  /// % de commission Pangee retenu (= prodExePct au moment du recompute).
  commissionPct    Decimal?
  /// Montant € de la commission Pangee (= revenue × pct / 100).
  commissionAmount Decimal?
  /// Montant € qui revient à l'artiste (= margin − commissionAmount).
  artistAmount     Decimal?

  /// Statut consolidé de paiement de la Part Artiste (driver UI séparé du
  /// DealArtiste.paymentStatus individuel — Stan 2026-05-27 v2 : pill "Payé"
  /// global du show, indépendant des cachets individuels).
  artistStatus     PaymentStatus @default(N_A)

  // ── Lignes de production (Sprint 4) ──
  productionLines ProductionLine[]

  // ── Prestations facturées (Sprint 5 CACHETS) — N prestataires/mois ──
  cachetPrestations CachetPrestation[]

  /// Échéancier de paiement (Stan 2026-06-13) — BOOKING uniquement. Découpe le
  /// `budgetAmount` reçu de l'organisateur en N tranches datées (acompte +
  /// solde…), chacune avec son statut d'encaissement et son mois réel. Quand
  /// des échéances existent, `budgetPaymentStatus` / `budgetPaidAt` sont
  /// dérivés de leur état (cf. lib/finance/deal-installments.ts) — le toggle
  /// "Encaissé" global est remplacé par l'échéancier. PROD_EXE (ProductionLine)
  /// et CACHETS (CachetPrestation) ont déjà du multi-ligne daté → exclus.
  installments DealInstallment[]

  /// Tâches du deal (Sprint 6 — Stan 2026-05-31). Instanciées auto à la
  /// création depuis `TaskTemplate where category = deal.category`. Cascade
  /// delete via la relation Task → Deal.
  tasks Task[]

  // ── Audit multi-user ──
  /// User qui a créé ce deal. SetNull si l'user est désactivé (préserve
  /// l'historique sans casser la contrainte FK).
  createdById String?
  createdBy   User?   @relation("DealCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  /// Soft-delete (règle B3 verrouillée). Cascade vers DealArtiste côté
  /// server action — pas Prisma onDelete qui supprimerait définitivement.
  deletedAt DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
  @@index([category])
  @@index([date])
}

/// Jointure Deal × Artist avec champs financiers individuels.
///
/// Un deal Pangee peut concerner 1-N artistes (1 le plus souvent, 2-3 pour
/// les plateaux). Chaque artiste a son cachet + sa com Pangee + des statuts
/// paiement indépendants.
///
/// La com Pangee GLOBALE du deal est calculée à la volée (`SUM(commissionAmount)`).
/// Pas stockée sur Deal pour éviter la désync.
///
/// Decimal pour les montants — préserve la précision (Prisma sur SQLite
/// stocke en TEXT, sur Postgres en numeric).
///
/// Contrainte d'unicité (dealId, artistId) : un artiste ne peut apparaître
/// qu'une fois par deal. Pour ajouter le même artiste avec 2 cachets
/// différents, créer 2 deals séparés.
model DealArtiste {
  id String @id @default(cuid())

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  artistId String
  /// onDelete: Restrict — bloque la suppression d'un Artist si des DealArtiste
  /// actifs le référencent. L'user doit "détacher" l'artiste des deals avant
  /// (ou les supprimer en cascade soft-delete depuis le Deal parent).
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Restrict)

  /// Montant que touche l'artiste pour ce deal (€). Champ DB `cachetAmount`,
  /// label UI "Montant" (Stan 2026-05-26). Pangee paie ce montant à l'artiste
  /// depuis le budget reçu de l'organisateur.
  cachetAmount Decimal?

  /// Part de l'artiste sur le budget Pangee (%, ex. 30.0 = 30 %). Optionnel.
  /// Si renseigné, le montant peut se calculer auto côté UI :
  /// `cachetAmount = Deal.budgetAmount * sharePct / 100`. L'user peut override
  /// le montant manuellement (le % reste à titre informatif).
  sharePct Decimal?

  /// Statut paiement de l'artiste (Pangee a-t-il versé sa rémunération ?).
  /// Wording identique KN : À facturer / Facturée / Encaissée / Litige / N_A.
  paymentStatus PaymentStatus @default(N_A)

  /// Mois où l'artiste a été payé par Pangee (cash-flow réel sortant).
  /// Sert au reporting + filtre période.
  paidAt DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Soft-delete cascade depuis Deal (set par server action quand Deal
  /// est soft-delete). Permet de restaurer tout l'arbre depuis /trash.
  deletedAt DateTime?

  @@unique([dealId, artistId])
  @@index([artistId])
  @@index([deletedAt])
}

/// Charges diverses d'un deal — dépenses Pangee (transports, hôtels, technique,
/// repas, frais externes). Refonte modèle 2026-05-26 (Stan) : la marge Pangee
/// est dérivée comme `Deal.budgetAmount - SUM(DealArtiste.cachetAmount)
/// - SUM(DealCharge.amount)`.
///
/// Suit le même pattern de statut paiement / mois encaissement que DealArtiste,
/// car Pangee paie ces charges à des fournisseurs externes.
model DealCharge {
  id String @id @default(cuid())

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  /// Libellé court de la charge (ex. "Hôtel Mercure Paris", "Train Paris-Lyon").
  label String

  /// Montant de la charge (€).
  amount Decimal?

  /// Statut paiement (Pangee a-t-il payé ?).
  paymentStatus PaymentStatus @default(N_A)

  /// Mois de paiement effectif (cash-flow réel sortant).
  paidAt DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Soft-delete cascade depuis Deal (idem DealArtiste).
  deletedAt DateTime?

  @@index([dealId])
  @@index([deletedAt])
}

/// Ligne du tableau de production (Sprint 4) — recettes + charges d'un deal
/// Prod Exécutive. Copie fidèle KN `ProductionLine`.
///
/// Le calcul de la marge Pangee dérive de la somme des `REVENUE` − `COST`,
/// puis Pangee retient `prodExePct` % du CA (revenue). Cf.
/// `lib/finance/show-financials.ts` pour le recompute server-side.
///
/// Plusieurs lignes peuvent partager le même `label` (sous-entrées multi —
/// ex. VHR = train + hôtel + repas). Le champ `customLabel` sert à préciser
/// le sous-libellé. Pas de contrainte d'unicité sur (dealId, label).
model ProductionLine {
  id String @id @default(cuid())

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  /// Recette ou charge.
  kind ProductionLineKind

  /// Catégorie figée enum (Stan ne peut pas créer de nouvelles catégories).
  label ProductionLineLabel

  /// Sous-libellé texte libre (ex. "Train Paris-Lyon" sous label VHR).
  customLabel String?

  /// Montant € (Decimal pour préserver la précision).
  amount Decimal?

  /// Statut paiement de la ligne (sortie cash ou encaissement).
  paymentStatus PaymentStatus @default(N_A)

  /// Mois où la ligne a été réglée / encaissée.
  paidAt DateTime?

  /// Commentaire libre.
  comment String?

  /// Flag "Pris par la salle" — uniquement pertinent en mode CO_REAL. Si
  /// true, la ligne n'est pas comptée dans la marge Pangee (la salle l'a
  /// payée en direct).
  coveredByVenue Boolean @default(false)

  /// Ordre d'affichage (drag & drop éventuel futur).
  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Soft-delete cascade depuis Deal (idem DealArtiste / DealCharge).
  deletedAt DateTime?

  @@index([dealId])
  @@index([deletedAt])
}

/// Reversement Pangee → associé sur un deal (cadre prestation de services).
/// 1 ligne par (deal × catégorie × associé). Le pool % (10 par défaut) est
/// modifiable par catégorie au cas par cas, puis réparti équitablement
/// entre les N associés sélectionnés (sharePct = pool ÷ N).
///
/// Le montant € est snapshot (calculé au moment du set) pour préserver
/// l'historique même si la marge change après — Stan peut le re-calculer
/// manuellement via le bouton "Recalculer" si besoin.
model DealManagementFee {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  role ManagementFeeRole

  /// Clé associé (stan/certe/angath) — pointe vers lib/pangee-team.ts.
  /// Migrera vers FK userId quand on aura User.phone (task #47).
  associateKey String

  /// % de la marge Youri attribué à CET associé (= pool ÷ nb personnes).
  /// Ex : pool 10% partagé entre 2 personnes → sharePct = 5 chacun.
  sharePct Decimal

  /// Montant € snapshot (= margeYouri × sharePct / 100). Stocké pour
  /// préserver l'historique même si la marge change après.
  amount Decimal?

  /// Statut paiement Pangee → société de l'associé (cycle facturation).
  paymentStatus PaymentStatus @default(N_A)

  /// Mois de paiement effectif (cash-flow Pangee sortant).
  paidAt DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Soft-delete cascade depuis Deal (idem DealArtiste/DealCharge).
  deletedAt DateTime?

  @@unique([dealId, role, associateKey])
  @@index([dealId])
  @@index([associateKey])
  @@index([deletedAt])
}

// ─────────────────────────── Cachet · Prestations (Sprint 5) ───────────────────────────
//
// Modèle CACHETS Stan 2026-05-28 : 1 deal = 1 artiste × 1 mois, mais N
// prestations facturées à des sociétés différentes (chacune avec son budget).
// Le cachet artiste total = Σ prestations × (100 − cachetsFeesPct)%, la
// Marge Brute Pangee = Σ prestations × cachetsFeesPct%.
//
// Le scalar `Deal.budgetAmount` est recalculé automatiquement comme somme
// des `CachetPrestation.amount` actives (recompute server-side dans
// `lib/finance/cachets-finance.ts`).

model CachetPrestation {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  /// Nom libre de la société facturée. Pas de lien avec l'annuaire Contact
  /// (Stan : facture à une société, pas besoin d'un contact référencé).
  prestataire String

  /// Montant facturé en € (HT par convention — la TVA est gérée en compta).
  amount Decimal?

  /// Statut paiement de la facture (workflow Pangee → tiers).
  paymentStatus PaymentStatus @default(N_A)

  /// Mois d'encaissement effectif (cash-flow Pangee entrant).
  paidAt DateTime?

  notes String?

  /// Ordre d'affichage dans le form / fiche détail.
  order Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Soft-delete cascade depuis Deal.
  deletedAt DateTime?

  @@index([dealId, deletedAt])
}

// ─────────────────────────── Échéancier de paiement (Stan 2026-06-13) ───────────────────────────
//
// BOOKING uniquement. Un deal Booking reçoit un `budgetAmount` de l'organisateur
// payé en une ou plusieurs tranches (acompte à la signature + solde après le
// show, par ex.). Chaque DealInstallment = une tranche datée avec son montant,
// son statut d'encaissement et son mois réel d'encaissement.
//
// Modèle inspiré de KN `DealInstallment` mais SIMPLIFIÉ : KN a 2 axes de statut
// (artiste + commission) car ses deals ont 2 flux ; côté Youri Booking il n'y a
// qu'UN axe = l'encaissement du budget Pangee (la part artiste est gérée
// séparément par DealArtiste). Pas de soft-delete (édition inline = vrai delete,
// comme les charges/prestations le faisaient avant — ici on hard-delete car
// l'échéancier est une donnée de structure, pas un historique).
//
// Quand des échéances existent, le recompute (deal-installments.ts) dérive
// `Deal.budgetPaymentStatus` (agrégat) + `Deal.budgetPaidAt` (date max des
// tranches PAID) → s'intègre au dashboard/reporting comme une encaisse normale.
// La somme des tranches doit égaler `budgetAmount` (contrôle côté UI).
model DealInstallment {
  id     String @id @default(cuid())
  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  /// Libellé libre de la tranche (ex. "Acompte signature", "Solde prestation").
  label String

  /// Montant brut de cette tranche (part du budgetAmount du deal). Decimal
  /// pour préserver la précision (SQLite TEXT, Postgres numeric).
  amount Decimal?

  /// Date d'échéance prévue de la tranche. Optionnelle — sert de date
  /// d'affichage et de base au mois d'encaissement par défaut.
  dueDate DateTime?

  /// Statut d'encaissement de cette tranche (workflow Pangee → organisateur).
  /// Wording identique aux autres statuts : À facturer / Facturée / Encaissée /
  /// Litige / N_A.
  paymentStatus PaymentStatus @default(N_A)

  /// Mois d'encaissement réel de la tranche (cash-flow entrant). Sert à la
  /// ventilation mensuelle dashboard/reporting (chaque tranche à son mois).
  paidAt DateTime?

  /// Ordre d'affichage (0, 1, 2…) — préserve l'ordre saisi.
  sortOrder Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([dealId])
}

// ─────────────────────────── Tâches (Sprint 6) ───────────────────────────
//
// Modèle inspiré de Youri V1 mais refondu en table dédiée (vs JSON) avec
// templates éditables depuis /settings/templates (vs hardcodés en code).
//
// Workflow Stan 2026-05-31 :
//   - Chaque catégorie de deal (BOOKING / PROD_EXE / CACHETS) a un pipeline
//     ordonné de TaskTemplate (étapes génériques avec assigné par défaut).
//   - À la création d'un deal → instanciation auto des templates en Task
//     avec snapshot intégral du label/assignee/dueAt (l'édition ultérieure
//     du template ne touche pas les Task existantes).
//   - Pour un user X, la "tâche courante" affichée dans /taches = la 1re
//     Task TODO assignée à X dans chaque deal (ordonnée par `order`).
//   - Au validate → status passe à DONE → la Task suivante apparait.

enum TaskStatus {
  TODO
  DONE
  SKIPPED
}

/// Étape générique d'un pipeline de tâches par catégorie de deal.
/// Éditable côté `/settings/templates` (ADMIN only). Les modifications ici
/// ne touchent QUE les nouveaux deals — les deals existants conservent
/// leur pipeline snapshot.
model TaskTemplate {
  id String @id @default(cuid())

  /// Catégorie de deal cible (BOOKING / PROD_EXE / CACHETS).
  category DealCategory

  /// Position dans le pipeline (0-N). Tri ASC.
  order Int

  /// Libellé court (ex. "Envoyer devis"). Snapshot copié vers Task.label.
  label String

  /// Description optionnelle (consigne, pré-requis…).
  description String?

  /// Clé pangee (stan/certe/angath) de l'associé responsable par défaut.
  /// null = "à attribuer" — l'user choisira au moment de prendre la tâche.
  defaultAssigneeKey String?

  /// Délai en jours par rapport à `Deal.date` pour calculer `Task.dueAt`.
  /// Positif = APRÈS la date du show (ex. encaissement J+15).
  /// Négatif = AVANT (ex. envoyer devis J−30).
  /// null = pas de deadline auto.
  defaultDueOffsetDays Int?

  /// Soft-delete (préserve les Task existantes via SetNull sur templateId).
  deletedAt DateTime?

  /// Reverse de Task.template — permet d'auditer combien d'instances ont été
  /// créées depuis ce template (et de bloquer la suppression définitive si
  /// besoin, géré côté server action).
  tasks Task[] @relation("TaskFromTemplate")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category, order, deletedAt])
}

/// Instance de tâche rattachée à un deal. Créée auto à `createDeal` depuis
/// les templates actifs de la catégorie. Snapshot du template au create
/// (label/assigneeKey/dueAt) pour préserver l'historique si le template
/// est modifié après.
model Task {
  id String @id @default(cuid())

  dealId String
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  /// Référence au template d'origine (null si tâche custom ajoutée à la main).
  /// SetNull si template supprimé pour préserver la trace.
  templateId String?
  template   TaskTemplate? @relation("TaskFromTemplate", fields: [templateId], references: [id], onDelete: SetNull)

  /// Position dans le pipeline du deal (copié du template au create, modifiable).
  order Int

  /// Snapshot du label (modifiable au cas par cas sur le deal).
  label String

  description String?

  /// Snapshot pangee key. Pattern cohérent avec DealManagementFee.associateKey
  /// (préserve l'historique si user désactivé).
  assigneeKey String?

  /// Statut : TODO (à faire), DONE (validée), SKIPPED (ignorée — non applicable).
  status TaskStatus @default(TODO)

  /// Date d'échéance snapshot (= deal.date + template.defaultDueOffsetDays).
  /// Modifiable manuellement après création.
  dueAt DateTime?

  /// Audit : moment où la tâche a été validée (status=DONE/SKIPPED).
  doneAt DateTime?

  /// Audit : user qui a validé la tâche. SetNull si user désactivé pour
  /// préserver la trace historique.
  doneByUserId String?
  doneBy       User?   @relation("TaskDoneBy", fields: [doneByUserId], references: [id], onDelete: SetNull)

  /// Notes libres (raison de skip, contexte de validation…).
  notes String?

  /// Soft-delete cascade depuis Deal.
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Index pour la query "tâches d'un deal triées par ordre".
  @@index([dealId, status, order])
  /// Index pour la query "mes tâches courantes" (filtré sur user + TODO).
  @@index([assigneeKey, status, deletedAt])
  @@index([deletedAt])
}

// ─────────────────────────── FDR / Feuille de route (Sprint 3.7) ───────────────────────────
//
// Copie fidèle du modèle KN `EventBriefing` adaptée Youri (cf. enums
// BriefingStatus/BriefingRole/TravelDirection en haut de fichier).
//
// Pattern snapshot pour Venue + Contact : Pangee n'a pas de tables locales
// (annuaire vit côté KN distant). Pour les contacts on stocke `contactId`
// snapshot + champs inline (toujours peuplés — soit copiés depuis KN, soit
// saisis libre pour les rôles ponctuels VTC/runner).

/// Feuille de route d'un deal Booking. 1-1 avec Deal. Créée à la demande
/// via `ensureBriefingWithPrefill(dealId)` — la FDR vide n'existe pas tant
/// que l'user n'a pas ouvert la page /fdr.
model EventBriefing {
  id     String @id @default(cuid())
  dealId String @unique
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  // ── Snapshot lieu (Venue KN distant — pattern identique Deal) ──
  venueId      String?
  venueName    String?
  venueCity    String?
  /// Adresse libre (free-text + BAN data.gouv.fr) — copiée depuis Deal.venueAddress
  /// au prefill, ou complétée à la main sur la FDR. Couvre les 2 cas Pangee :
  ///   - Lieu de l'annuaire KN : l'adresse complète n'est pas forcément en BDD
  ///   - Booking entreprise sans lieu KN : seule source d'adresse
  /// Stan 2026-05-26 : "reprendre l'info complète depuis le deal".
  venueAddress String?

  showTime    String?
  /// Heure des balances (sound check / mise en place). Texte libre.
  balanceTime String?

  /// Jauge (capacité du lieu). Auto-remplie depuis Venue KN au pick du lieu,
  /// modifiable à la main (cas booking sans lieu KN ou capacité différente
  /// de la jauge par défaut du lieu).
  capacity Int?

  // ── Hébergement (free-text + adresse BAN data.gouv.fr) ──
  hotelName    String?
  hotelAddress String?

  // ── Restauration (free-text + adresse BAN + flag "pris en charge") ──
  /// `restaurantCovered=true` couvre le cas "le client paye le restau mais
  /// on n'a pas encore l'adresse exacte" — utile pour indiquer à l'artiste
  /// que le repas est OK sans préciser le lieu.
  restaurantName    String?
  restaurantAddress String?
  restaurantCovered Boolean @default(false)

  // ── Per diem (indemnité repas) ──
  perDiemFlag   Boolean  @default(false)
  perDiemAmount Decimal?

  // ── Relations ──
  travels  BriefingTravel[]
  contacts BriefingContact[]

  // ── Notes libres + status workflow ──
  notes  String?
  status BriefingStatus @default(DRAFT)

  /// Date du dernier envoi par email aux artistes (UTC). Sert au badge
  /// "Envoyée le X" + permet de bloquer un renvoi accidentel.
  sentAt DateTime?

  /// Soft-delete pour cohérence avec Deal (cascade côté server action).
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
}

/// Trajet rattaché à une FDR (aller / retour / inter-étapes).
/// `runs` stocke une liste JSON de transferts (taxi, voiture) attachés
/// au trajet — voir commentaire détaillé sur le champ.
model BriefingTravel {
  id         String        @id @default(cuid())
  briefingId String
  briefing   EventBriefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)

  direction   TravelDirection
  date        DateTime
  fromStation String
  fromTime    String
  toStation   String
  toTime      String
  comment     String?

  /// "Runs" (transferts) optionnels — voiture / VTC.
  ///
  /// Stocké en JSON : `Array<{ location: string, time: string }>` — plusieurs
  /// runs par trajet (ex. gare → hôtel puis hôtel → salle).
  ///
  /// Sémantique selon `direction` :
  ///   - OUTBOUND : suite de pickups APRÈS l'arrivée
  ///   - RETURN   : suite de pickups AVANT le départ
  ///   - INTER    : transferts libres entre étapes
  runs Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([briefingId])
}

/// Contact rattaché à une FDR avec un rôle métier (production, régisseur,
/// VTC, tour manager, organisateur, technicien, autre).
///
/// Pattern snapshot annuaire KN :
///   - `contactId` non null = snapshot d'un Contact KN distant (refetch
///     possible via kn-client si besoin de rafraîchir les coordonnées)
///   - `contactId` null = saisie libre "inline" (rôle ponctuel — runner,
///     VTC qui change à chaque date — pas la peine de polluer l'annuaire KN)
/// Dans les 2 cas, les champs `firstName/lastName/...` sont peuplés (soit
/// copiés depuis KN au moment de la sélection, soit saisis manuellement).
model BriefingContact {
  id         String        @id @default(cuid())
  briefingId String
  briefing   EventBriefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)

  contactId String?

  firstName String?
  lastName  String?
  company   String?
  phone     String?
  email     String?

  role BriefingRole

  createdAt DateTime @default(now())

  @@index([briefingId])
}

// ─────────────────────────── APP RUNTIME ───────────────────────────

/// Key-value store pour les settings runtime (flags features, version
/// migration, etc.). Sera enrichi au fil des sprints.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

// ─────────────────────────── AUDIT (Sprint 10) ───────────────────────────

/// Journal d'audit des opérations sensibles (create / update / delete /
/// restore / permanently_delete). Copie du pattern KuroNeko `AuditEntry`,
/// enrichi d'un ACTEUR (`actorId` + `actorName` snapshot) car Youri est
/// multi-user (Stan / Certe / Angath) — on veut savoir QUI a fait l'action.
///
/// Écrit en best-effort par `logAudit()` (lib/audit.ts) : ne bloque jamais
/// le flux métier si l'insertion échoue. Pas d'UI d'historique dédiée pour
/// l'instant (comme KN) — surfacé en compteur dans /settings.
model AuditEntry {
  id       String @id @default(cuid())
  entity   String /// ex: "Deal", "Task", "Artist"
  entityId String
  action   String /// "create" | "update" | "delete" | "restore" | "permanently_delete"
  before   String? /// JSON stringifié de l'état antérieur (tronqué à 5000 car.)
  summary  String? /// Description courte ("Deal supprimé : « … »")

  /// Acteur de l'opération. SetNull si l'user est supprimé ; `actorName`
  /// conserve la trace lisible même sans relation.
  actorId   String?
  actor     User?   @relation("AuditActor", fields: [actorId], references: [id], onDelete: SetNull)
  actorName String?

  createdAt DateTime @default(now())

  @@index([entity, entityId])
  @@index([createdAt])
  @@index([actorId])
}
