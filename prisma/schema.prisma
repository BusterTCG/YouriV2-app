// Youri V2 — Prisma schema
// Source : docs/architecture-decisions.md § Modèle de données
// Local : SQLite. Production (VPS) : switch to postgresql via DATABASE_URL.
//
// Sprint 0 : datasource + generator + AppSetting (key/value store, sert de
// smoke test pour la 1re migration et de base future pour les settings runtime).
// Les modèles métier (User, Artist, Deal, Task, etc.) viennent au Sprint 1+.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─────────────────────────── ENUMS ───────────────────────────

/// Rôle d'un utilisateur. Convention décisions verrouillées :
/// - ADMIN : Stan uniquement. Peut gérer les autres users + éditer les
///   templates de tâches (Sprint 6).
/// - MEMBER : tout le monde fait TOUT (créer/modifier/supprimer n'importe
///   quel deal/tâche/artiste). Pas de restrictions métier.
/// Cf. docs/architecture-decisions.md § Users & permissions.
enum UserRole {
  ADMIN
  MEMBER
}

/// Source de l'authentification (audit, debug).
enum AuthSource {
  GOOGLE
  PASSWORD
}

/// Catégorie d'un deal Pangee. 3 valeurs (vs 5 côté KN — cf. règles V2) :
/// - BOOKING : cession/booking d'artistes auprès d'organisateurs (mono-date)
/// - PROD_EXE : production exécutive 15 % (multi-date, Sprint 4)
/// - CACHETS : gestion paie intermittents (multi-date, Sprint 5)
/// Sprint 3 = BOOKING uniquement. L'enum complet est créé dès Phase 3.1
/// pour éviter une migration future. Les filtres `/deals/booking` etc.
/// sélectionnent strictement par catégorie.
enum DealCategory {
  BOOKING
  PROD_EXE
  CACHETS
}

/// Statut d'un deal — workflow manuel simple (cf. décision archi B1 verrouillée).
/// - LEAD : prospect / négociation amont
/// - EN_COURS : négociation avancée mais pas signée
/// - CONFIRME : deal signé / confirmé
/// - ANNULE : pas fait (négo échouée ou annulation post-confirmation)
enum DealStatus {
  LEAD
  EN_COURS
  CONFIRME
  ANNULE
}

/// Statut de paiement — utilisé pour les 2 niveaux par artiste sur DealArtiste :
/// - paymentStatus = statut du cachet artiste (ce que l'artiste reçoit)
/// - commissionStatus = statut de la commission Pangee (ce que Pangee perçoit)
/// Les 2 sont indépendants car cachet et com sont facturés / payés séparément.
///
/// DISPUTE = paiement en litige (impayé contesté). Identique KN. Stan veut
/// le même wording / mêmes propositions que KN dans les Selects.
enum PaymentStatus {
  TO_INVOICE
  VALIDATED
  INVOICED
  PAID
  DISPUTE
  N_A
}

// ─────────────────────────── FDR / Feuille de route (Sprint 3.7) ───────────────────────────
//
// Reprise fidèle du modèle KN `EventBriefing` (cf. AGENTS.md règle copie
// fidèle KN). Adaptations Youri V2 :
//   - Pas de tables Hotel/Restaurant/Venue locales : tout en free-text +
//     adresse BAN (Venue vit côté KN distant, snapshot pattern).
//   - Pas de relation Contact locale : BriefingContact stocke `contactId`
//     snapshot KN + champs inline (Pangee veut éviter de polluer l'annuaire
//     pour les rôles ponctuels VTC/runner).
//   - Multi-artiste : 1 FDR commune au deal (Stan validé 2026-05-26),
//     envoyée à tous les artistes du deal.
//   - Catégorie BOOKING uniquement pour Sprint 3.7 — PROD_EXE/CACHETS
//     viendront aux Sprints 4/5.

enum BriefingStatus {
  DRAFT
  COMPLETE
  SENT
}

enum TravelDirection {
  OUTBOUND
  RETURN
  INTER
}

enum BriefingRole {
  PRODUCTION
  REGISSEUR
  VTC
  TOUR_MANAGER
  ORGANISATEUR
  TECHNICIEN
  AUTRE
}

// ─────────────────────────── USERS (Sprint 1) ───────────────────────────

/// Compte utilisateur Pangee Prod. 3 seedés au bootstrap :
/// Stan (ADMIN), Certe (MEMBER), Angath (MEMBER).
///
/// Pas de soft-delete (pas de `deletedAt`) — on désactive via `active: false`
/// au lieu de supprimer, pour préserver l'historique d'audit / completedBy
/// sur les tâches que l'user a validées (à venir Sprint 6).
model User {
  id            String   @id @default(cuid())

  /// Email principal (login). Pour les users avec Google OAuth, c'est aussi
  /// l'email Google. Unique.
  email         String   @unique

  /// Nom d'affichage (sidebar, badges, "Validé par X").
  name          String

  /// Hash bcrypt du mot de passe de secours (fallback si Google down).
  /// Tous les users ont le même mdp au démarrage (APP_PASSWORD). Réinitia-
  /// lisable depuis /settings/users par l'ADMIN.
  passwordHash  String

  /// Couleur d'identification de l'user (badges "assigné à", chips). Hex.
  color         String   @default("#3b82f6")

  /// Rôle (ADMIN | MEMBER). Voir enum UserRole pour les implications.
  role          UserRole @default(MEMBER)

  /// Désactiver = empêche le login mais préserve l'historique des actions.
  /// Préféré à un soft-delete pour la traçabilité.
  active        Boolean  @default(true)

  /// Trace la dernière source d'auth (debug si problème OAuth vs mdp).
  lastAuthSource AuthSource?
  lastLoginAt    DateTime?

  /// Relations d'audit — quel user a créé quel deal (multi-user audit léger).
  /// Sprint 10 ajoutera un AuditEntry plus complet pour les actions update/delete.
  dealsCreated   Deal[] @relation("DealCreatedBy")

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ─────────────────────────── MASTER DATA (Sprint 2) ───────────────────────────

/// Artiste managé / produit par Pangee Prod.
///
/// Table dédiée Youri — PAS partagée avec KuroNeko (roster différent).
/// Soft-deletable (`deletedAt`) avec garde côté server action : on bloque
/// la suppression si des DealArtiste actifs référencent l'artiste (cf.
/// docs/architecture-decisions.md § Cascade soft-delete). DealArtiste sera
/// ajouté Sprint 3.
///
/// Structure repompée à l'identique de KuroNeko-App (cf. AGENTS.md règle
/// "copie fidèle de KN") : avatar avec position de recadrage + fiche
/// ArtistProfile complète en relation 1-1 (identité civile, SACD,
/// intermittence, structure, RIB, bio, social).
model Artist {
  id        String    @id @default(cuid())

  /// Nom d'affichage de l'artiste. Unique pour éviter doublons accidentels.
  name      String    @unique

  /// Slug pour les URLs `/artistes/[slug]`. Généré depuis `name` via lib/slug.ts.
  /// Unique. Si l'user crée 2 fois "Jean Dupont", le slug aura un suffixe -2.
  slug      String    @unique

  /// Couleur d'identification (badges, chips, avatar). Hex.
  /// Pangee gère 50+ artistes — pas de couleurs distinctes par artiste
  /// (cf. règle 2026-05-26, lib/artists-constants.ts PANGEE_ARTIST_COLOR).
  /// On garde le champ en BDD pour compat / option future, mais l'UI
  /// force toujours la même couleur à la création/modif.
  color     String    @default("#2563eb")

  /// URL relative vers la photo d'avatar uploadée (ex. "/uploads/avatars/<id>-<ts>.jpg").
  /// Null = pas de photo, on affiche le fallback initiales+couleur. Fichier stocké
  /// dans `public/uploads/avatars/` côté serveur.
  avatarUrl String?

  /// Position horizontale du recadrage avatar dans le rond (0-100 %, défaut 50 = centré).
  /// Appliqué via CSS `object-position`. Permet de re-centrer la photo si le sujet
  /// n'est pas au milieu du fichier source (typique iPhone portrait).
  avatarPositionX Float @default(50)

  /// Position verticale du recadrage avatar (0-100 %, défaut 50 = centré).
  avatarPositionY Float @default(50)

  /// Notes libres internes (style musical, préférences, infos contractuelles
  /// rapides). La fiche complète vit dans ArtistProfile relation 1-1.
  notes     String?

  /// Désactiver = masquer dans les listes par défaut. Soft-delete via
  /// `deletedAt` reste l'opération "définitive" (visible dans /trash Sprint 10).
  active    Boolean   @default(true)

  deletedAt DateTime?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  profile      ArtistProfile?
  /// Deals où cet artiste apparaît (jointure DealArtiste avec cachet + com
  /// + statuts paiement individuels). Sprint 3+.
  dealArtistes DealArtiste[]
}

// ─────────────────────────── ARTIST PROFILE (Sprint 2-bis) ───────────────────────────
// Fiche complète d'identité, structure, RIB et communication d'un artiste.
// Relation 1-1 avec Artist (optionnelle — créée à la demande via upsert).
// Champs sensibles (Sécu, IBAN) gérés en masquage à l'affichage (composant InfoField).
//
// Schéma repris à l'identique de KuroNeko-App ArtistProfile (cf. AGENTS.md
// règle "copie fidèle de KN" — Pangee a le même besoin métier pour la
// gestion paie intermittents + facturation cachets).

model ArtistProfile {
  id       String @id @default(cuid())
  artistId String @unique
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  // 1 — Identité civile
  firstName              String?
  lastName               String?
  stageName              String?
  birthDate              DateTime?
  birthPlace             String?
  nationality            String?
  socialSecurityNumber   String?
  intermittentNumber     String?
  sacdNumber             String?

  // 2 — Coordonnées personnelles
  personalEmail   String?
  personalPhone   String?
  homeAddress     String?

  // 3 — Structure de facturation
  companyName       String?
  companyLegalForm  String?
  companySiret      String?
  companySiren      String?
  companyVatNumber  String?
  companyApeCode    String?
  companyAddress    String?
  spectacleLicense  String?
  vatRegime         String?

  // 4 — Coordonnées bancaires
  bankIban    String?
  bankBic     String?
  bankName    String?
  bankHolder  String?

  // 5 — Communication / Press kit
  bioShort         String?
  bioLong          String?
  pressPhotoUrl    String?
  websiteUrl       String?
  instagramHandle  String?
  youtubeHandle    String?
  tiktokHandle     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─────────────────────────── DEALS (Sprint 3) ───────────────────────────
//
// Sprint 3 ne gère que `category=BOOKING` (mono-date). PROD_EXE (Sprint 4) et
// CACHETS (Sprint 5) sont multi-date — on ajoutera une table DealDate jointe
// à ce moment-là. L'enum DealCategory inclut déjà les 3 valeurs pour éviter
// une migration future.
//
// Pattern annuaire = snapshot (cf. project-youri-v2 décisions verrouillées) :
// Deal stocke organizerId/Name/Company/City + venueId/Name/City. Pas de
// relation Prisma — l'annuaire vit côté KN (lib/kn-client). On refetch via
// API KN uniquement quand l'user clique "Modifier ce contact" / "ce lieu".
//
// Multi-artiste : relation DealArtiste avec cachet + commission + 2 statuts
// paiement par artiste (cachet payé indépendant de com Pangee payée).
//
// Multi-user audit : createdById sur Deal (qui a créé). Sprint 10 ajoutera
// un AuditEntry plus complet pour update/delete.
//
// Soft-delete : deletedAt sur Deal et DealArtiste. Cascade côté server action
// (pas Prisma cascade qui supprimerait vraiment).

/// Deal Pangee — entité métier centrale du Sprint 3+. Représente une opération
/// commerciale (booking, prod exécutive, cachets) avec 1-N artistes.
model Deal {
  id          String       @id @default(cuid())

  /// Catégorie discriminante (BOOKING / PROD_EXE / CACHETS). Sprint 3 = BOOKING
  /// uniquement. Filtre strict côté pages `/deals/<categorie>`.
  category    DealCategory

  /// Workflow simple manuel (LEAD → EN_COURS → CONFIRME / ANNULE).
  /// L'user passe les statuts à la main depuis la fiche deal.
  status      DealStatus   @default(LEAD)

  /// Titre court du deal (ex. "Nordine Ganso @ Comedy Club Paris").
  /// Souvent généré auto depuis artiste(s) + lieu, modifiable.
  title       String

  /// Description / contexte libre (notes commerciales en amont, terms négociés).
  description String?

  /// Date principale du deal. Pour BOOKING (mono-date) c'est LA date du show.
  /// Pour PROD_EXE/CACHETS (multi-date) c'est la 1re date — la liste complète
  /// sera stockée dans DealDate (Sprint 4+).
  date        DateTime

  /// Heure du show — texte libre ("20h30", "doors 19h / show 20h"). Pas
  /// parsé, juste affiché. Indépendant de la date pour préserver la flexibilité.
  showTime    String?

  // ── Budget Pangee (modèle 2026-05-26 : budget global vs marge) ──
  // Stan a refondé le modèle : Pangee touche un budget global de l'organisateur,
  // paie les artistes (DealArtiste.cachetAmount) et les charges (DealCharge.amount),
  // et garde la différence = Marge Pangee. Plus de commission % par artiste.

  /// Budget Pangee = montant que l'organisateur paie à Pangee pour ce deal.
  /// Sert de base au calcul de la Marge Pangee = budget − total artistes − total charges.
  budgetAmount  Decimal?

  /// Statut du budget côté Pangee (à facturer / facturée / encaissée / litige).
  /// En UI, sur la fiche deal, exposé comme checkbox simple "Encaissé"
  /// (true = PAID, false = N_A ou TO_INVOICE). Dans le tableau récap inline,
  /// Select 5 valeurs comme les autres statuts paiement.
  budgetPaymentStatus PaymentStatus @default(N_A)

  /// Mois où Pangee a encaissé le budget de l'organisateur (cash-flow réel).
  /// Sert au filtre période axis="paid" + reporting mensuel marge.
  budgetPaidAt  DateTime?

  // ── Snapshot organisateur (Contact KN distant) ──
  /// ID du Contact KN au moment de la sélection. Refetch via kn-client.
  organizerId      String?
  /// Nom complet snapshotté (firstName + lastName concaténés ou company).
  /// Désync acceptable avec KN jusqu'au prochain "Modifier ce contact".
  organizerName    String?
  organizerCompany String?
  organizerCity    String?

  // ── Snapshot lieu (Venue KN distant) ──
  venueId    String?
  venueName  String?
  venueCity  String?
  /// Adresse libre (BAN data.gouv.fr) — utilisée quand le lieu n'est PAS un
  /// Venue référencé en BDD (ex. booking entreprise). Si venueId est null,
  /// venueCity est extraite automatiquement depuis cette adresse (regex code
  /// postal). Cas Stan 2026-05-26 : "booking en entreprise" sans référencer
  /// le lieu dans l'annuaire.
  venueAddress String?

  // ── Multi-artiste ──
  dealArtistes DealArtiste[]

  // ── Charges diverses (dépenses Pangee) ──
  dealCharges  DealCharge[]

  // ── Feuille de route (Sprint 3.7) ──
  /// 1-1 optionnel : la FDR n'existe que si l'user l'a ouverte au moins
  /// une fois (auto-création via ensureBriefingWithPrefill). Cascade
  /// delete suit le soft-delete du Deal côté server action.
  briefing     EventBriefing?

  // ── Audit multi-user ──
  /// User qui a créé ce deal. SetNull si l'user est désactivé (préserve
  /// l'historique sans casser la contrainte FK).
  createdById  String?
  createdBy    User?  @relation("DealCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  /// Soft-delete (règle B3 verrouillée). Cascade vers DealArtiste côté
  /// server action — pas Prisma onDelete qui supprimerait définitivement.
  deletedAt DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
  @@index([category])
  @@index([date])
}

/// Jointure Deal × Artist avec champs financiers individuels.
///
/// Un deal Pangee peut concerner 1-N artistes (1 le plus souvent, 2-3 pour
/// les plateaux). Chaque artiste a son cachet + sa com Pangee + des statuts
/// paiement indépendants.
///
/// La com Pangee GLOBALE du deal est calculée à la volée (`SUM(commissionAmount)`).
/// Pas stockée sur Deal pour éviter la désync.
///
/// Decimal pour les montants — préserve la précision (Prisma sur SQLite
/// stocke en TEXT, sur Postgres en numeric).
///
/// Contrainte d'unicité (dealId, artistId) : un artiste ne peut apparaître
/// qu'une fois par deal. Pour ajouter le même artiste avec 2 cachets
/// différents, créer 2 deals séparés.
model DealArtiste {
  id       String @id @default(cuid())

  dealId   String
  deal     Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  artistId String
  /// onDelete: Restrict — bloque la suppression d'un Artist si des DealArtiste
  /// actifs le référencent. L'user doit "détacher" l'artiste des deals avant
  /// (ou les supprimer en cascade soft-delete depuis le Deal parent).
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Restrict)

  /// Montant que touche l'artiste pour ce deal (€). Champ DB `cachetAmount`,
  /// label UI "Montant" (Stan 2026-05-26). Pangee paie ce montant à l'artiste
  /// depuis le budget reçu de l'organisateur.
  cachetAmount    Decimal?

  /// Part de l'artiste sur le budget Pangee (%, ex. 30.0 = 30 %). Optionnel.
  /// Si renseigné, le montant peut se calculer auto côté UI :
  /// `cachetAmount = Deal.budgetAmount * sharePct / 100`. L'user peut override
  /// le montant manuellement (le % reste à titre informatif).
  sharePct Decimal?

  /// Statut paiement de l'artiste (Pangee a-t-il versé sa rémunération ?).
  /// Wording identique KN : À facturer / Facturée / Encaissée / Litige / N_A.
  paymentStatus   PaymentStatus @default(N_A)

  /// Mois où l'artiste a été payé par Pangee (cash-flow réel sortant).
  /// Sert au reporting + filtre période.
  paidAt    DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Soft-delete cascade depuis Deal (set par server action quand Deal
  /// est soft-delete). Permet de restaurer tout l'arbre depuis /trash.
  deletedAt DateTime?

  @@unique([dealId, artistId])
  @@index([artistId])
  @@index([deletedAt])
}

/// Charges diverses d'un deal — dépenses Pangee (transports, hôtels, technique,
/// repas, frais externes). Refonte modèle 2026-05-26 (Stan) : la marge Pangee
/// est dérivée comme `Deal.budgetAmount - SUM(DealArtiste.cachetAmount)
/// - SUM(DealCharge.amount)`.
///
/// Suit le même pattern de statut paiement / mois encaissement que DealArtiste,
/// car Pangee paie ces charges à des fournisseurs externes.
model DealCharge {
  id       String @id @default(cuid())

  dealId   String
  deal     Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  /// Libellé court de la charge (ex. "Hôtel Mercure Paris", "Train Paris-Lyon").
  label    String

  /// Montant de la charge (€).
  amount   Decimal?

  /// Statut paiement (Pangee a-t-il payé ?).
  paymentStatus PaymentStatus @default(N_A)

  /// Mois de paiement effectif (cash-flow réel sortant).
  paidAt   DateTime?

  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Soft-delete cascade depuis Deal (idem DealArtiste).
  deletedAt DateTime?

  @@index([dealId])
  @@index([deletedAt])
}

// ─────────────────────────── FDR / Feuille de route (Sprint 3.7) ───────────────────────────
//
// Copie fidèle du modèle KN `EventBriefing` adaptée Youri (cf. enums
// BriefingStatus/BriefingRole/TravelDirection en haut de fichier).
//
// Pattern snapshot pour Venue + Contact : Pangee n'a pas de tables locales
// (annuaire vit côté KN distant). Pour les contacts on stocke `contactId`
// snapshot + champs inline (toujours peuplés — soit copiés depuis KN, soit
// saisis libre pour les rôles ponctuels VTC/runner).

/// Feuille de route d'un deal Booking. 1-1 avec Deal. Créée à la demande
/// via `ensureBriefingWithPrefill(dealId)` — la FDR vide n'existe pas tant
/// que l'user n'a pas ouvert la page /fdr.
model EventBriefing {
  id     String @id @default(cuid())
  dealId String @unique
  deal   Deal   @relation(fields: [dealId], references: [id], onDelete: Cascade)

  // ── Snapshot lieu (Venue KN distant — pattern identique Deal) ──
  venueId   String?
  venueName String?
  venueCity String?

  showTime    String?
  /// Heure des balances (sound check / mise en place). Texte libre.
  balanceTime String?

  // ── Hébergement (free-text + adresse BAN data.gouv.fr) ──
  hotelName    String?
  hotelAddress String?

  // ── Restauration (free-text + adresse BAN + flag "pris en charge") ──
  /// `restaurantCovered=true` couvre le cas "le client paye le restau mais
  /// on n'a pas encore l'adresse exacte" — utile pour indiquer à l'artiste
  /// que le repas est OK sans préciser le lieu.
  restaurantName    String?
  restaurantAddress String?
  restaurantCovered Boolean @default(false)

  // ── Per diem (indemnité repas) ──
  perDiemFlag   Boolean  @default(false)
  perDiemAmount Decimal?

  // ── Relations ──
  travels  BriefingTravel[]
  contacts BriefingContact[]

  // ── Notes libres + status workflow ──
  notes  String?
  status BriefingStatus @default(DRAFT)

  /// Date du dernier envoi par email aux artistes (UTC). Sert au badge
  /// "Envoyée le X" + permet de bloquer un renvoi accidentel.
  sentAt DateTime?

  /// Soft-delete pour cohérence avec Deal (cascade côté server action).
  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([deletedAt])
}

/// Trajet rattaché à une FDR (aller / retour / inter-étapes).
/// `runs` stocke une liste JSON de transferts (taxi, voiture) attachés
/// au trajet — voir commentaire détaillé sur le champ.
model BriefingTravel {
  id         String          @id @default(cuid())
  briefingId String
  briefing   EventBriefing   @relation(fields: [briefingId], references: [id], onDelete: Cascade)

  direction   TravelDirection
  date        DateTime
  fromStation String
  fromTime    String
  toStation   String
  toTime      String
  comment     String?

  /// "Runs" (transferts) optionnels — voiture / VTC.
  ///
  /// Stocké en JSON : `Array<{ location: string, time: string }>` — plusieurs
  /// runs par trajet (ex. gare → hôtel puis hôtel → salle).
  ///
  /// Sémantique selon `direction` :
  ///   - OUTBOUND : suite de pickups APRÈS l'arrivée
  ///   - RETURN   : suite de pickups AVANT le départ
  ///   - INTER    : transferts libres entre étapes
  runs Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([briefingId])
}

/// Contact rattaché à une FDR avec un rôle métier (production, régisseur,
/// VTC, tour manager, organisateur, technicien, autre).
///
/// Pattern snapshot annuaire KN :
///   - `contactId` non null = snapshot d'un Contact KN distant (refetch
///     possible via kn-client si besoin de rafraîchir les coordonnées)
///   - `contactId` null = saisie libre "inline" (rôle ponctuel — runner,
///     VTC qui change à chaque date — pas la peine de polluer l'annuaire KN)
/// Dans les 2 cas, les champs `firstName/lastName/...` sont peuplés (soit
/// copiés depuis KN au moment de la sélection, soit saisis manuellement).
model BriefingContact {
  id         String @id @default(cuid())
  briefingId String
  briefing   EventBriefing @relation(fields: [briefingId], references: [id], onDelete: Cascade)

  contactId String?

  firstName String?
  lastName  String?
  company   String?
  phone     String?
  email     String?

  role BriefingRole

  createdAt DateTime @default(now())

  @@index([briefingId])
}

// ─────────────────────────── APP RUNTIME ───────────────────────────

/// Key-value store pour les settings runtime (flags features, version
/// migration, etc.). Sera enrichi au fil des sprints.
model AppSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}
